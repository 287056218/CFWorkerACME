{
  "name": "CFWorkerACME",
  "scripts": {
    "build": "npm --prefix frontend run build",
    "web-dev": "npm --prefix frontend run dev",
    "web-build": "npm --prefix frontend run build",
    "web-install": "npm --prefix frontend install",
    "dev-js": "tsx watch src/basic.ts",
    "build-js": "webpack --mode production",
    "deploy-js": "node dist/bundle.js",
    "dev-cf": "npm run patch:acme && wrangler dev",
    "dev-cf:test": "npm run patch:acme && wrangler dev -c ./wrangler.encrypt.jsonc",
    "deploy-cf": "npm run patch:acme && wrangler deploy --minify",
    "deploy-cf:test": "npm run patch:acme && wrangler deploy --minify -c ./wrangler.encrypt.jsonc",
    "dev-eo": "edgeone pages dev",
    "build-eo": "edgeone pages build",
    "deploy-eo": "edgeone pages deploy ./ -n workacme-web -t ",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "patch:acme": "patch-package",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@edgeone/ef-types": "^1.0.5",
    "@hono/node-server": "^1.16.0",
    "acme-client": "^5.4.0",
    "axios": "^1.9.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.0.1",
    "edgeone": "^1.1.18",
    "hono": "^4.7.7",
    "jszip": "^3.10.1",
    "node-forge": "^1.3.1",
    "resend": "^4.4.1",
    "xior": "^0.7.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@serverless-devs/s": "^3.1.10",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.14.1",
    "@types/node-forge": "^1.3.11",
    "esbuild": "^0.25.5",
    "patch-package": "^8.0.1",
    "ts-loader": "^9.5.1",
    "tsx": "^4.7.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "wrangler": "^4.3.0"
  },
  "overrides": {}
}
