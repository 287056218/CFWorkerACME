// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // 默认使用 sqlite，实际生产环境下可通过 DATABASE_URL 覆盖为 mysql。
  // 本项目通过环境变量 DB_SOURCE 选择后端：
  //   - "" 或 "d1"  => Cloudflare D1（不走 Prisma）
  //   - "mysql"     => 直连 mysql2
  //   - "prisma"    => 使用 PrismaClient（DATABASE_URL 指向真实 DB）
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户表：与 schema.sql 结构保持一致（Prisma 使用 mail 作为主键）
model Users {
  mail     String  @id @unique
  flag     String  @default("0")
  code     String?
  keys     String?
  pass     String?
  apis     String?
  time     BigInt?
  is_admin Int     @default(0)
  quota    Int     @default(-1)
}

// 证书申请表
model Apply {
  uuid String  @id @unique
  mail String
  sign Int?
  type Int?
  auto Int     @default(0)
  flag Int     @default(0)
  time BigInt? @default(0)
  next BigInt? @default(0)
  main String
  list String
  keys String?
  cert String?
  data String?
  text String?
}

// 系统配置表
model Confs {
  name String  @id @unique
  data String?
  time BigInt?
}

// 保留原 Authy 模型（当前未启用）
model Authy {
  user Int
  type Int
  hash String @unique
  time String
  name String
  data String
}